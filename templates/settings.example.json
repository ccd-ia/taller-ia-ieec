{
  "permissions": {
    "deny": [
      "Read(./.env*)",
      "Edit(./.env*)",
      "Write(./.env*)",
      "Read(./secretos/**)",
      "Read(./datos-sensibles/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/credenciales*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[hook] Se guardó un archivo. Recuerda revisar el diff antes de continuar.'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/revisar-perimetro.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
